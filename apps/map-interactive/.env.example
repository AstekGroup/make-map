# MapTiler API Key (free plan: 100k requests/month)
# Get your free key at https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_KEY=your_maptiler_key_here

# Airtable API Configuration
# Personal Access Token from https://airtable.com/create/tokens
VITE_AIRTABLE_API_KEY=your_airtable_pat_here
# Base ID (starts with "app")
VITE_AIRTABLE_BASE_ID=your_base_id_here
# Table ID (starts with "tbl") - using ID avoids URL encoding issues with French table names
VITE_AIRTABLE_TABLE_ID=your_table_id_here

# ============================================================
# Variables d'environnement pour le déploiement production
# Copier ce fichier en .env.prod et remplir les valeurs
# ============================================================

# Airtable API (backend)
AIRTABLE_API_KEY=your_airtable_pat_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_ID=your_table_id_here

# Frontend
VITE_MAPTILER_KEY=your_maptiler_key_here

# Domaine (pour HTTPS automatique via Caddy/Let's Encrypt)
# Utiliser "localhost" pour le développement local
# Utiliser le vrai domaine en production (ex: map.semaine-ia.fr)
DOMAIN=localhost

# CORS (laisser * pour autoriser tous les origines, ou mettre le domaine précis)
CORS_ORIGIN=*
